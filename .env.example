# ============================================
# QUEUEPLAY - SaaS CONFIGURATION
# ============================================

PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# PostgreSQL Database
# Railway auto-sets this when Postgres is added to the project.
# For local dev, run `brew install postgresql` and set your local connection string.
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/queueplay

# ============================================
# QueuePlay's own Spotify Developer App
# These are PLATFORM-level credentials (one set for the whole SaaS).
# Venues do NOT create their own app - they just click "Connect" in the admin panel.
# ============================================
# 1. Create an app at: https://developer.spotify.com/dashboard
# 2. Add this Redirect URI to the app settings:
#    https://queueplay-jukebox-production.up.railway.app/auth/spotify/callback
# 3. Copy the Client ID and Client Secret below.
SPOTIFY_CLIENT_ID=platform_queueplay_spotify_client_id
SPOTIFY_CLIENT_SECRET=platform_queueplay_spotify_client_secret

# Super Admin Platform Config
SUPER_ADMIN_KEY=master-platform-key-here

# Salt for password hashing
SALT=queueplay-secrets-salt-key
