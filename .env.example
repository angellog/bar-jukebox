# ============================================
# QUEUEPLAY - SaaS CONFIGURATION
# ============================================

PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# Spotify API Developer Credentials
# Get yours here: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Super Admin Platform Config
SUPER_ADMIN_KEY=master-platform-key-here

# Database Path
DATABASE_PATH=./database/queueplay.db

# Salt for password hashing
SALT=queueplay-secrets-salt-key
