{
  "name": "queueplay",
  "version": "2.0.0",
  "description": "White-label SaaS music queue for cafes, restaurants, and public spaces. Guests scan a QR code, pick a song, and it plays through the venue's speakers.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:reset": "rm -rf database/*.db && node src/server.js"
  },
  "keywords": [
    "jukebox",
    "spotify",
    "music",
    "saas",
    "multi-tenant",
    "cafe",
    "restaurant"
  ],
  "author": "angellog",
  "license": "MIT",
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": "20.x"
  }
}
